                "src/system/pauseSystem.cpp",
                "src/system/settings.cpp",
                "src/scenes/mainMenu.cpp",
                "-I",
                "src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-o",
